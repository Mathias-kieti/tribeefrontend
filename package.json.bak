{
	"name": "tribe_trc-systems",
	"private": false,
	"version": "1.0.0",
	"description": "Tribe powered by TRC Systems",
	"author": "TRIBE Team<R.D.M>",
	"license": "MIT",
	"type": "module",
	"main": "electron/main.js",
	"homepage": "https://github.com/d3george/slash-admin",
	"scripts": {
		"start": "vite",
		"dev": "vite",
		"build:web": "vite build",
		"preview": "vite preview",
		"preinstall": "echo 'Skipping lefthook for Windows'",
		"electron:dev": "concurrently -k \"vite --port 3000\" \"wait-on http://localhost:3000 && electron .\"",
		"electron:build": "echo 'No local build needed - Loading from http://38.242.155.236'",
		"electron:start": "electron .",
		"electron:package": "electron-builder",
		"electron:package:win": "electron-builder --win nsis portable",
		"electron:package:win-installer": "electron-builder --win nsis",
		"electron:package:win-portable": "electron-builder --win portable",
		"electron:package:win-all": "electron-builder --win nsis portable msi",
		"electron:package:mac": "electron-builder --mac",
		"electron:package:linux": "electron-builder --linux",
		"postinstall": "electron-builder install-app-deps"
	},
	"dependencies": {
		"@ant-design/cssinjs": "^1.24.0",
		"@dnd-kit/core": "^6.3.1",
		"@dnd-kit/sortable": "^10.0.0",
		"@dnd-kit/utilities": "^3.2.2",
		"@fontsource-variable/inter": "^5.1.0",
		"@fontsource-variable/open-sans": "^5.1.0",
		"@fullcalendar/core": "^6.1.15",
		"@fullcalendar/daygrid": "^6.1.15",
		"@fullcalendar/interaction": "^6.1.15",
		"@fullcalendar/list": "^6.1.15",
		"@fullcalendar/react": "^6.1.15",
		"@fullcalendar/timegrid": "^6.1.15",
		"@hookform/resolvers": "^5.0.1",
		"@iconify/react": "^4.1.1",
		"@iconify/utils": "^2.3.0",
		"@tailwindcss/vite": "^4.1.3",
		"@tanstack/react-query": "^5.60.2",
		"@vanilla-extract/css": "^1.17.0",
		"@vanilla-extract/vite-plugin": "^5.0.7",
		"@vercel/analytics": "^1.5.0",
		"@vitejs/plugin-react": "^4.3.3",
		"antd": "^5.22.1",
		"apexcharts": "^4.5.0",
		"axios": "^1.7.7",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"cmdk": "^1.1.1",
		"color": "^4.2.3",
		"concurrently": "^8.0.1",
		"cross-env": "^7.0.3",
		"date-fns": "^3.6.0",
		"dayjs": "^1.11.13",
		"electron-squirrel-startup": "^1.0.0",
		"electron-updater": "^6.6.2",
		"framer-motion": "^12.23.22",
		"highlight.js": "^11.10.0",
		"i18next": "^23.16.5",
		"i18next-browser-languagedetector": "^7.2.1",
		"input-otp": "^1.4.2",
		"jwt-decode": "^4.0.0",
		"lucide-react": "^0.487.0",
		"motion": "^12.9.0",
		"numeral": "^2.0.6",
		"qrcode.react": "^4.0.0",
		"radix-ui": "^1.4.3",
		"ramda": "^0.29.1",
		"react": "^18.2.0",
		"react-apexcharts": "^1.5.0",
		"react-day-picker": "^8.10.1",
		"react-dom": "^18.2.0",
		"react-helmet-async": "^2.0.5",
		"react-hook-form": "^7.56.1",
		"react-i18next": "^13.5.0",
		"react-is": "^18.2.0",
		"react-quill": "^1.3.5",
		"react-router": "^7.0.2",
		"react-use": "^17.5.1",
		"recharts": "^3.2.1",
		"screenfull": "^6.0.2",
		"sonner": "^1.7.0",
		"styled-components": "^6.1.13",
		"tailwind-merge": "^3.2.0",
		"tw-animate-css": "^1.2.5",
		"vaul": "^1.1.2",
		"zod": "^3.24.3",
		"zustand": "^4.5.5"
	},
	"devDependencies": {
		"@biomejs/biome": "2.1.3",
		"@commitlint/cli": "^17.8.1",
		"@commitlint/config-conventional": "^17.8.1",
		"@faker-js/faker": "^8.4.1",
		"@types/color": "^3.0.6",
		"@types/numeral": "^2.0.5",
		"@types/ramda": "^0.29.12",
		"@types/react": "^18.2.0",
		"@types/react-dom": "^18.2.0",
		"@types/styled-components": "^5.1.34",
		"electron": "^28.3.3",
		"electron-builder": "^24.13.3",
		"lefthook": "^1.8.2",
		"msw": "^2.6.4",
		"rollup-plugin-visualizer": "^5.12.0",
		"shiki": "^3.6.0",
		"tailwindcss": "^4.1.3",
		"typescript": "^5.6.3",
		"vite": "^6.3.6",
		"vite-plugin-static-copy": "^3.1.4",
		"vite-tsconfig-paths": "^5.1.2",
		"wait-on": "^7.2.0"
	},
	"engines": {
		"node": ">=18.0.0"
	},
	"overrides": {
		"qrcode.react": "^4.0.0"
	},
	"build": {
		"appId": "com.loyaltyengine.desktop",
		"productName": "TRIBE",
		"copyright": "Copyright © 2025 TRIBE",
		"directories": {
			"output": "dist-electron",
			"buildResources": "electron/build-resources"
		},
		"files": [
			"electron/**/*",
			"!electron/**/*.map",
			"package.json",
			"node_modules/electron-updater/**/*"
		],
		"win": {
			"target": "nsis",
			"icon": "electron/build-resources/icon.ico",
			"publisherName": "TRIBE"
		},
		"mac": {
			"target": [
				"dmg",
				"zip"
			],
			"icon": "electron/build-resources/icon.icns",
			"category": "public.app-category.business",
			"hardenedRuntime": true,
			"gatekeeperAssess": false,
			"entitlements": "electron/entitlements.mac.plist",
			"entitlementsInherit": "electron/entitlements.mac.plist"
		},
		"linux": {
			"target": [
				"AppImage",
				"deb",
				"rpm"
			],
			"icon": "electron/build-resources/icon.png",
			"category": "Office",
			"artifactName": "tribe_${version}_${arch}.${ext}"
		},
		"nsis": {
			"oneClick": false,
			"allowToChangeInstallationDirectory": true,
			"createDesktopShortcut": true,
			"createStartMenuShortcut": true,
			"shortcutName": "TRIBE",
			"installerIcon": "electron/build-resources/icon.ico",
			"uninstallerIcon": "electron/build-resources/tray-icon.ico"
		},
		"publish": [
			{
				"provider": "generic",
				"url": "http://38.242.155.236/downloads/"
			}
		],
		"asar": true,
		"asarUnpack": [
			"node_modules/electron-squirrel-startup/**/*",
			"node_modules/electron-updater/**/*"
		],
		"npmRebuild": true,
		"nodeGypRebuild": false,
		"buildDependenciesFromSource": false
	},
	"msw": {
		"workerDirectory": [
			"public"
		]
	},
	"commitlint": {
		"extends": [
			"@commitlint/config-conventional"
		]
	}
}
